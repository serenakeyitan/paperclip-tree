{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "npx -p first-tree first-tree tree inject-context --skip-version-check",
            "statusMessage": "Loading First Tree context"
          }
        ]
      }
    ]
  }
}
